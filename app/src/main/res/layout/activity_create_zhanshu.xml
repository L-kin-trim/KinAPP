<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="创建战术"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:textColor="#212121" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="战术类型"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:textColor="#212121" />
            <Spinner
                android:id="@+id/zhanshu_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E0E0E0"
                android:spinnerMode="dropdown"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="战术名称"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:textColor="#212121" />
            <EditText
                android:id="@+id/zhanshu_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入战术名称"
                android:inputType="text"
                android:background="#E0E0E0"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="战术描述"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:textColor="#212121" />
            <EditText
                android:id="@+id/zhanshu_description"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="请输入战术描述"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="#E0E0E0"
                android:padding="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="成员分配"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textColor="#212121" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <EditText
                    android:id="@+id/member1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="成员1"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
                <EditText
                    android:id="@+id/member1_role"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="角色/任务"
                    android:layout_marginLeft="8dp"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <EditText
                    android:id="@+id/member2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="成员2"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
                <EditText
                    android:id="@+id/member2_role"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="角色/任务"
                    android:layout_marginLeft="8dp"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <EditText
                    android:id="@+id/member3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="成员3"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
                <EditText
                    android:id="@+id/member3_role"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="角色/任务"
                    android:layout_marginLeft="8dp"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <EditText
                    android:id="@+id/member4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="成员4"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
                <EditText
                    android:id="@+id/member4_role"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="角色/任务"
                    android:layout_marginLeft="8dp"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/member5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="成员5"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
                <EditText
                    android:id="@+id/member5_role"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="角色/任务"
                    android:layout_marginLeft="8dp"
                    android:inputType="text"
                    android:background="#E0E0E0"
                    android:padding="8dp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">
            <Button
                android:id="@+id/cancel_button"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="取消"
                android:layout_marginRight="16dp"
                android:background="#607D8B"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />
            <Button
                android:id="@+id/save_button"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="保存"
                android:background="#388E3C"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
